<?xml version="1.0" encoding="utf-8"?>
<!--
  Outline-only border for an image note, drawn as a foreground on top of the bitmap so the edge stays
  visible. Matches the text/voice box outline: a faint neutral hairline by default that swaps to the
  accent-red outline in the activated (urgent) state. The fill is transparent so the image shows
  through.
-->
<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <item android:state_activated="true">
        <shape android:shape="rectangle">
            <solid android:color="@android:color/transparent" />
            <corners android:radius="18dp" />
            <stroke
                android:width="1.5dp"
                android:color="@color/notesUrgent" />
        </shape>
    </item>

    <item>
        <shape android:shape="rectangle">
            <solid android:color="@android:color/transparent" />
            <corners android:radius="18dp" />
            <stroke
                android:width="0.8dp"
                android:color="?attr/primaryColorTrans50" />
        </shape>
    </item>

</selector>
