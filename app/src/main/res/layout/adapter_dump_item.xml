<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="end"
    android:orientation="vertical"
    android:paddingHorizontal="16dp"
    android:paddingVertical="6dp">

    <TextView
        android:id="@+id/dumpText"
        style="@style/TextSmall"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/rounded_rect_shade_color"
        android:maxWidth="320dp"
        android:paddingHorizontal="16dp"
        android:paddingVertical="12dp"
        android:textColor="?attr/primaryColor"
        android:textIsSelectable="true"
        tools:text="Remember to buy milk and call the bank tomorrow." />

    <ImageView
        android:id="@+id/dumpImage"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:adjustViewBounds="true"
        android:contentDescription="@string/dump_image_desc"
        android:maxWidth="280dp"
        android:maxHeight="360dp"
        android:scaleType="fitEnd"
        android:visibility="gone"
        tools:src="@drawable/logo"
        tools:visibility="visible" />

    <TextView
        android:id="@+id/dumpTime"
        style="@style/TextSmallLight"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:layout_marginEnd="4dp"
        android:textSize="11sp"
        tools:text="3 Jun, 9:41 AM" />

</LinearLayout>
