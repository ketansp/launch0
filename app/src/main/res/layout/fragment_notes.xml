<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:id="@+id/notesRoot"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="?attr/primaryShadeDarkColor"
        android:orientation="vertical">

        <!-- Header: back affordance · title · entry count -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="14dp"
            android:layout_marginEnd="18dp"
            android:layout_marginTop="14dp"
            android:layout_marginBottom="6dp"
            android:baselineAligned="false"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/notesBack"
                style="@style/TextLarge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/notes_back"
                android:paddingHorizontal="6dp"
                android:paddingVertical="2dp"
                android:text="@string/notes_back_symbol"
                android:textColor="?attr/primaryColor"
                android:textSize="26sp" />

            <TextView
                android:id="@+id/notesTitle"
                style="@style/TextLarge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:text="@string/notes_title"
                android:textColor="?attr/primaryColor"
                android:textSize="22sp" />

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

            <TextView
                android:id="@+id/notesCount"
                style="@style/TextSmallLight"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="?attr/primaryColorTrans50"
                android:textSize="12sp"
                tools:text="13 entries" />

        </LinearLayout>

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerView"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:clipChildren="false"
                android:clipToPadding="false"
                android:fadingEdgeLength="24dp"
                android:paddingTop="8dp"
                android:paddingBottom="8dp"
                android:requiresFadingEdge="vertical"
                tools:listitem="@layout/adapter_notes_item" />

            <TextView
                android:id="@+id/notesEmpty"
                style="@style/TextSmallLight"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginHorizontal="48dp"
                android:gravity="center"
                android:text="@string/notes_empty_hint"
                android:visibility="gone"
                tools:visibility="visible" />

        </FrameLayout>

        <!-- Status banner for editing / search modes; tap ✕ to clear -->
        <LinearLayout
            android:id="@+id/notesBanner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:visibility="gone"
            tools:visibility="visible">

            <TextView
                android:id="@+id/notesBannerText"
                style="@style/TextSmallLight"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textSize="12sp"
                tools:text="Editing note" />

            <TextView
                android:id="@+id/notesBannerClear"
                style="@style/TextSmall"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/cancel"
                android:padding="8dp"
                android:text="✕"
                android:textColor="?attr/primaryColor" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/notesInputBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="12dp"
            android:layout_marginVertical="8dp"
            android:gravity="bottom"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/notesAttach"
                style="@style/TextLarge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/notes_add_image"
                android:minWidth="40dp"
                android:paddingHorizontal="6dp"
                android:paddingVertical="8dp"
                android:text="@string/notes_attach_symbol"
                android:textColor="?attr/primaryColor" />

            <TextView
                android:id="@+id/notesRecord"
                style="@style/TextSmall"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/notes_record_desc"
                android:minWidth="40dp"
                android:gravity="center"
                android:paddingHorizontal="6dp"
                android:paddingVertical="12dp"
                android:text="@string/notes_record_symbol"
                android:textColor="?attr/primaryColor" />

            <EditText
                android:id="@+id/notesInput"
                style="@style/TextSmall"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical"
                android:layout_weight="1"
                android:background="@drawable/rounded_rect_shade_color"
                android:hint="@string/notes_input_hint"
                android:inputType="textMultiLine|textCapSentences"
                android:maxLines="5"
                android:minHeight="44dp"
                android:paddingHorizontal="16dp"
                android:paddingVertical="10dp"
                android:textColor="?attr/primaryColor"
                android:textColorHint="?attr/primaryColorTrans50"
                android:textCursorDrawable="@null"
                android:importantForAutofill="no"
                tools:ignore="Autofill" />

            <TextView
                android:id="@+id/notesRecording"
                style="@style/TextSmall"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical"
                android:layout_weight="1"
                android:gravity="center_vertical"
                android:minHeight="44dp"
                android:paddingHorizontal="16dp"
                android:paddingVertical="10dp"
                android:textColor="?attr/primaryColor"
                android:visibility="gone"
                tools:text="Recording… 0:05"
                tools:visibility="visible" />

            <TextView
                android:id="@+id/notesSearch"
                style="@style/TextSmall"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical"
                android:background="?attr/selectableItemBackground"
                android:paddingHorizontal="10dp"
                android:paddingVertical="12dp"
                android:text="@string/notes_search"
                android:textAllCaps="false"
                android:textColor="?attr/primaryColor" />

            <TextView
                android:id="@+id/notesSend"
                style="@style/TextSmallBold"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical"
                android:background="?attr/selectableItemBackground"
                android:paddingHorizontal="10dp"
                android:paddingVertical="12dp"
                android:text="@string/notes_send"
                android:textAllCaps="false"
                android:textColor="?attr/primaryColor" />

        </LinearLayout>

    </LinearLayout>

    <!-- Full-screen image viewer; tap anywhere to dismiss -->
    <FrameLayout
        android:id="@+id/notesImageViewer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/blackTrans90"
        android:clickable="true"
        android:focusable="true"
        android:visibility="gone"
        tools:visibility="gone">

        <ImageView
            android:id="@+id/notesFullImage"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_margin="12dp"
            android:adjustViewBounds="true"
            android:contentDescription="@string/notes_image_desc"
            android:scaleType="fitCenter" />

    </FrameLayout>

</FrameLayout>
