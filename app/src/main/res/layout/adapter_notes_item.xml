<?xml version="1.0" encoding="utf-8"?>
<!--
  One timeline entry. Everything is left-aligned and uses the full content width, like a
  chat-with-yourself log: text notes are flat (shadowed text on the wallpaper, no bubble) with the
  to-do toggles pinned to the far right; images and voice memos sit in their own left-aligned tiles;
  every entry's timestamp sits bottom-left, consistent across all three types.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingHorizontal="18dp"
    android:paddingVertical="7dp">

    <!-- Text note (doubles as a to-do): text fills the width, toggles pin to the extreme right -->
    <LinearLayout
        android:id="@+id/notesTextRow"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:baselineAligned="false"
        android:gravity="top"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/notesText"
            style="@style/TextSmall"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:lineSpacingMultiplier="1.25"
            android:textColor="?attr/primaryColor"
            android:textIsSelectable="true"
            android:textSize="16sp"
            tools:text="Remember to buy milk and call the bank tomorrow." />

        <!-- Urgent then done, pinned to the far right edge -->
        <LinearLayout
            android:id="@+id/notesToggles"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/notesUrgent"
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/notes_mark_urgent"
                android:padding="6dp"
                android:scaleType="fitCenter"
                android:src="@drawable/ic_lucide_flag"
                app:tint="?attr/primaryColorTrans50" />

            <ImageView
                android:id="@+id/notesDone"
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/notes_mark_done"
                android:padding="6dp"
                android:scaleType="fitCenter"
                android:src="@drawable/ic_lucide_circle"
                app:tint="?attr/primaryColorTrans50" />

        </LinearLayout>

    </LinearLayout>

    <!-- Image attachment, left-aligned -->
    <ImageView
        android:id="@+id/notesImage"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:adjustViewBounds="true"
        android:background="@drawable/rounded_image_clip"
        android:clipToOutline="true"
        android:contentDescription="@string/notes_image_desc"
        android:maxWidth="280dp"
        android:maxHeight="360dp"
        android:scaleType="fitStart"
        android:visibility="gone"
        tools:src="@drawable/logo"
        tools:visibility="visible" />

    <!-- Voice note chip: play/stop glyph + duration, left-aligned -->
    <LinearLayout
        android:id="@+id/notesAudio"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/rounded_rect_shade_color"
        android:gravity="center_vertical"
        android:minWidth="160dp"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:paddingVertical="10dp"
        android:visibility="gone"
        tools:visibility="visible">

        <TextView
            android:id="@+id/notesAudioIcon"
            style="@style/TextSmall"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/notes_play_symbol"
            android:textColor="?attr/primaryColor" />

        <TextView
            android:id="@+id/notesAudioDuration"
            style="@style/TextSmall"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:textColor="?attr/primaryColorTrans80"
            tools:text="0:12" />

    </LinearLayout>

    <!-- Timestamp: bottom-left for every entry type -->
    <TextView
        android:id="@+id/notesTime"
        style="@style/TextSmallLight"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:textColor="?attr/primaryColorTrans50"
        android:textSize="11sp"
        tools:text="9:41 AM" />

</LinearLayout>
