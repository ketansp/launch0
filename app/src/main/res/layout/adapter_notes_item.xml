<?xml version="1.0" encoding="utf-8"?>
<!--
  One timeline entry, left-aligned like a chat-with-yourself log. Each entry sits in its own box that
  is lifted off the wallpaper with a hairline border: text notes (which double as to-dos), images and
  voice memos all share a fixed ~75%-of-width column so every box reads at one consistent width that
  adapts across screen sizes. An urgent entry swaps its box outline for an accent-red one. Below every
  box a shared footer carries the timestamp (bottom-left) and the urgent/done toggles (bottom-right),
  outside the box, so the toggles read clearly against any note type.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingHorizontal="18dp"
    android:paddingVertical="7dp">

    <!-- Fixed-width box column (~75% of the content width); the trailing spacer holds the rest -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="3"
            android:orientation="vertical">

            <!-- Text note (doubles as a to-do) -->
            <LinearLayout
                android:id="@+id/notesTextBubble"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/notes_bubble"
                android:orientation="vertical"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:paddingTop="11dp"
                android:paddingBottom="11dp">

                <TextView
                    android:id="@+id/notesText"
                    style="@style/TextSmall"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:lineSpacingMultiplier="1.25"
                    android:textColor="?attr/primaryColor"
                    android:textIsSelectable="true"
                    android:textSize="16sp"
                    tools:text="Remember to buy milk and call the bank tomorrow." />

            </LinearLayout>

            <!-- Image attachment: rounded bordered tile filling the box column -->
            <ImageView
                android:id="@+id/notesImage"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:adjustViewBounds="true"
                android:background="@drawable/notes_image_fill"
                android:clipToOutline="true"
                android:contentDescription="@string/notes_image_desc"
                android:foreground="@drawable/notes_box_border"
                android:scaleType="fitStart"
                android:visibility="gone"
                tools:src="@drawable/logo"
                tools:visibility="visible" />

            <!-- Voice note chip: play/stop glyph + duration -->
            <LinearLayout
                android:id="@+id/notesAudio"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/notes_bubble"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp"
                android:paddingVertical="10dp"
                android:visibility="gone"
                tools:visibility="visible">

                <TextView
                    android:id="@+id/notesAudioIcon"
                    style="@style/TextSmall"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/notes_play_symbol"
                    android:textColor="?attr/primaryColor" />

                <TextView
                    android:id="@+id/notesAudioDuration"
                    style="@style/TextSmall"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:textColor="?attr/primaryColorTrans80"
                    tools:text="0:12" />

            </LinearLayout>

        </LinearLayout>

        <!-- Spacer: keeps the box column at ~75% width -->
        <Space
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />

    </LinearLayout>

    <!-- Shared footer: timestamp bottom-left, urgent/done toggles bottom-right (outside the box) -->
    <LinearLayout
        android:id="@+id/notesFooter"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/notesTime"
            style="@style/TextSmallLight"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="?attr/primaryColorTrans50"
            android:textSize="11sp"
            tools:text="9:41 AM" />

        <ImageView
            android:id="@+id/notesUrgent"
            android:layout_width="26dp"
            android:layout_height="26dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/notes_mark_urgent"
            android:padding="5dp"
            android:scaleType="fitCenter"
            android:src="@drawable/ic_lucide_flag"
            app:tint="?attr/primaryColorTrans50" />

        <ImageView
            android:id="@+id/notesDone"
            android:layout_width="26dp"
            android:layout_height="26dp"
            android:layout_marginStart="2dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/notes_mark_done"
            android:padding="5dp"
            android:scaleType="fitCenter"
            android:src="@drawable/ic_lucide_square_outline"
            app:tint="?attr/primaryColorTrans50" />

    </LinearLayout>

</LinearLayout>
